# URL to the Prism (GraphQL) schema endpoint — required for `npm run graphql-to-doc`.
# The backend host is not renamed; only the docs/var name is "Prism".
# Example: https://targeted-api.adgem.com/v1/offers
PRISM_SCHEMA_URL=

# Prism access token (Bearer) used to introspect the schema at generation time.
# Cognito issues short-lived access tokens via a refresh-token exchange — obtain
# one just before running `npm run graphql-to-doc`. NOT needed at build time:
# the Prism reference is generated locally and committed (see WS3 in docs/plans/).
PRISM_ACCESS_TOKEN=
